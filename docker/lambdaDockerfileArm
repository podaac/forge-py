FROM public.ecr.aws/lambda/python:3.12-arm64

ARG SOURCE

# Combine commands to reduce layers and use --no-cache for microdnf
RUN microdnf install -y gcc gcc-c++ make && \
    microdnf clean all && \
    rm -rf /var/cache/dnf

# Install dependencies in a single layer
RUN pip3 install --no-cache-dir \
    awslambdaric \
    --target $LAMBDA_TASK_ROOT && \
    pip3 install --no-cache-dir --force \
    --index-url https://pypi.org/simple/ \
    --extra-index-url https://test.pypi.org/simple/ \
    --target "${LAMBDA_TASK_ROOT}" ${SOURCE}

ENTRYPOINT []
CMD ["podaac.lambda_handler.lambda_handler.handler"]